{
  "expo": {
    "name": "ThermoSense",
    "slug": "thermosense",
    "version": "6.0.0",
    "orientation": "portrait",
    "icon": "./assets/imgs/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/imgs/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/imgs/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.carlos_filipe_0.thermosense"
    },
    "web": {
      "favicon": "./assets/imgs/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7cca5f65-4f84-4108-a9b6-b09255bfd5a3"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your storage so you can change your profile photo."
        }
      ]
    ]
  }
}